# LLM
LLM_API_BASE_URL=http://internal-llm-api/v1
LLM_API_KEY=your-key-here
LLM_MODEL=gpt-oss
LLM_MODEL_FAST=gemma3
LLM_MODEL_ACCURATE=gpt-oss

# MySQL App DB (세션/로그/few-shot 저장용)
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_NAME=APPDB
APP_DB_USER=voc_app
APP_DB_PASSWORD=your-password

# MySQL TC DB (read-only, Text-to-SQL 대상)
# TEST 환경: APP_DB_HOST와 동일한 서버, schema만 분리
# 운영 전환 시: TC 운영 DB 호스트로 교체
TC_DB_HOST=localhost
TC_DB_PORT=3306
TC_DB_NAME=tc_test
TC_DB_USER=voc_readonly
TC_DB_PASSWORD=your-password

# Confluence (Phase 2)
CONFLUENCE_BASE_URL=http://사내confluence
CONFLUENCE_TOKEN=your-token
CONFLUENCE_SPACE_KEY=TC

# Splunk (Phase 3)
SPLUNK_HOST=splunk.internal
SPLUNK_PORT=8089
SPLUNK_TOKEN=your-splunk-token
SPLUNK_INDEX=tc_logs

# 설정
LOG_LEVEL=INFO
